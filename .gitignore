# =============================================
# .gitignore — SaaS Churn Prediction Engine
# =============================================

# -----------------------------------------------
# DATA — all raw, interim, processed, and external
# -----------------------------------------------
data/raw/
data/interim/
data/processed/
data/external/
# Keep the data README for documentation
!data/raw/README.md

# -----------------------------------------------
# MODELS — all serialized models & artifacts
# -----------------------------------------------
models/*.pkl
models/*.joblib
models/*.h5
models/*.hdf5
models/*.keras
models/*.pt
models/*.pth
models/*.onnx
models/ml/*.pkl
models/ml/*.joblib
models/dl/
models/tuning/
models/registry/
# Keep .gitkeep placeholders
!models/dl/.gitkeep
!models/ml/.gitkeep
!models/tuning/.gitkeep
!models/registry/.gitkeep

# -----------------------------------------------
# NUMPY / SCIPY BINARY DATA
# -----------------------------------------------
*.npz
*.npy

# -----------------------------------------------
# MLflow — tracking server, runs, and database
# -----------------------------------------------
mlruns/
mlflow.db
mlartifacts/

# -----------------------------------------------
# LOGS
# -----------------------------------------------
logs/
*.log

# -----------------------------------------------
# PYTHON
# -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# -----------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------
venv/
venv_old/
env/
.venv/
.env

# -----------------------------------------------
# TEST / COVERAGE
# -----------------------------------------------
.coverage
.pytest_cache/
htmlcov/

# -----------------------------------------------
# JUPYTER
# -----------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------
# IDE
# -----------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------
# OS
# -----------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------
# REPORTS — generated figures (keep markdown/text)
# -----------------------------------------------
reports/figures/*.png
reports/figures/*.pdf
reports/figures/*.jpg
reports/figures/*.svg

# -----------------------------------------------
# MISC — temp files and scratch
# -----------------------------------------------
null
New folder/
tmp_*.py
tmp_*.txt
