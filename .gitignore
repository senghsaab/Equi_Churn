# =============================================
# .gitignore — SaaS Churn Prediction Engine
# =============================================

# --- Data (raw data should not be committed) ---
data/raw/
data/interim/
data/processed/*.csv

# --- Trained models ---
models/*.pkl
models/*.joblib

# --- Logs ---
logs/
*.log

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---
venv/
env/
.venv/
.env

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Reports (generated figures can be large) ---
reports/figures/*.png
reports/figures/*.pdf
